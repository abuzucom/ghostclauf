# ── Ghostclauf secrets (never commit the real .env) ──────────────────────────
# Register an application at https://dev.twitch.tv/console/apps to obtain these.
TWITCH_CLIENT_ID=your-app-client-id
TWITCH_CLIENT_SECRET=your-app-client-secret

# Where the bot's OAuth token (access + refresh) is persisted. Mounted as a
# volume in Docker so it survives restarts. Created/updated automatically.
TOKEN_STORE_PATH=./data/tokens.json

# OAuth redirect URI used ONLY by the one-time `npm run auth` flow.
# Must exactly match a redirect URI registered on your Twitch app.
AUTH_REDIRECT_URI=http://localhost:3000/callback

# Optional: path to the config file (defaults to ./config.yaml)
# CONFIG_PATH=./config.yaml

# Optional: log level (trace|debug|info|warn|error). Defaults to info.
# LOG_LEVEL=info
