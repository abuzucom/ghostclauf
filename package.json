{
  "name": "ghostclauf",
  "version": "0.3.0",
  "description": "Lightweight, extensible chat bot. First deployment: Twitch.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "ghostclauf": "dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "auth": "tsx src/tools/authFlow.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@twurple/api": "7.4.0",
    "@twurple/auth": "7.4.0",
    "@twurple/eventsub-ws": "7.4.0",
    "dotenv": "16.6.1",
    "luxon": "3.7.2",
    "pino": "9.14.0",
    "yaml": "2.9.0",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/luxon": "3.7.2",
    "@types/node": "22.20.1",
    "pino-pretty": "13.1.3",
    "tsx": "4.23.0",
    "typescript": "5.9.3",
    "vitest": "2.1.9"
  },
  "license": "MIT"
}
